# Выберите нужный провайдер и укажите API ключ

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
OPENAI_API_KEY=sk-...

# Порт сервера (по умолчанию 3000)
PORT=3000

# Telegram feedback bot
# Получить токен у @BotFather командой /newbot
TELEGRAM_BOT_TOKEN=

# Chat ID администратора — куда пересылать фидбек в реальном времени
# Узнать свой chat_id: написать @userinfobot в Telegram
TELEGRAM_ADMIN_CHAT_ID=

# Публичная ссылка на сервис (показывается в боте тем, кто ещё не пробовал)
APP_URL=https://
